<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="18" styleClass="view-container" fillWidth="true"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="application.controller.CatalogueController">

    <!-- ── Page Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Product Catalogue" styleClass="page-title" />
            <Label text="Browse and manage your entire product inventory"
                   style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
        </VBox>
    </HBox>

    <!-- ── Toolbar ─────────────────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍  Search by SKU, name, or category..."
                   prefWidth="340"
                   styleClass="search-field" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="countLabel" text=""
               style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
        <Button text="📄  Export CSV" onAction="#exportCsv" styleClass="secondary-btn"
                style="-fx-padding: 8px 16px;" />
    </HBox>

    <!-- ── Product Table ───────────────────────────────────────── -->
    <TableView fx:id="productTable" VBox.vgrow="ALWAYS" maxHeight="Infinity">
        <columns>
            <TableColumn fx:id="imageColumn"    text="Image"      prefWidth="80"  minWidth="60" />
            <TableColumn fx:id="skuColumn"      text="SKU"        prefWidth="110" minWidth="80" />
            <TableColumn fx:id="nameColumn"     text="Product"    prefWidth="240" minWidth="140" />
            <TableColumn fx:id="categoryColumn" text="Category"   prefWidth="140" minWidth="100" />
            <TableColumn fx:id="quantityColumn" text="Stock"      prefWidth="90"  minWidth="70" />
            <TableColumn fx:id="priceColumn"    text="Price"      prefWidth="100" minWidth="80" />
            <TableColumn fx:id="actionColumn"   text="Actions"    prefWidth="220" minWidth="180" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>
