<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="view-container" fillWidth="true"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="application.controller.SellingController">

    <!-- ── Page Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Point of Sale" styleClass="page-title" />
            <Label text="Search manually or scan a barcode to process a sale"
                   style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
        </VBox>
        <Button text="📱  Pair Scanner" onAction="#showQR" styleClass="primary-btn" />
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS" fillHeight="true">

        <!-- ── Left: Manual Search ──────────────────────────────────── -->
        <VBox spacing="14" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="kpi-card" minWidth="350">
            <Label text="MANUAL SEARCH" styleClass="kpi-title" />
            <TextField fx:id="searchField"
                       promptText="Type product name, category or SKU..."
                       styleClass="search-field" />
            <ListView fx:id="searchResultsList" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-padding: 0;" />
        </VBox>

        <!-- ── Right: Scanner display + Session cart ─────────────────── -->
        <VBox spacing="20" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="420">

            <!-- Last-scanned banner -->
            <VBox styleClass="kpi-card" alignment="CENTER" minHeight="90">
                <Label fx:id="latestScanLabel"
                       text="Waiting for barcode scan…"
                       wrapText="true" textAlignment="CENTER"
                       styleClass="scan-label" maxWidth="Infinity" />
            </VBox>

            <!-- Session cart -->
            <VBox styleClass="kpi-card" VBox.vgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Current Sale" styleClass="kpi-title"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <Button text="End Sale / Next" onAction="#resetSession"
                            styleClass="secondary-btn"
                            style="-fx-padding: 4px 10px; -fx-font-size: 11px;" />
                </HBox>

                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS"
                           style="-fx-pref-height: 9999;">
                    <columns>
                        <TableColumn fx:id="timeColumn"    text="Time"    prefWidth="90"  minWidth="80" />
                        <TableColumn fx:id="productColumn" text="Product" prefWidth="200" minWidth="140" />
                        <TableColumn fx:id="priceColumn"   text="Price"   prefWidth="80"  minWidth="70" />
                        <TableColumn fx:id="actionColumn"  text=""        prefWidth="85"  minWidth="80" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- Session totals and checkout -->
                <VBox spacing="8" style="-fx-border-color: #334155; -fx-border-width: 1 0 0 0; -fx-padding: 10px 0 0 0;">
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="Subtotal:" style="-fx-text-fill: #7B90A8; -fx-font-size: 13px;" />
                        <Label fx:id="subtotalLabel" text="0.00" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;" />
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label fx:id="taxTextLabel" text="Tax:" style="-fx-text-fill: #7B90A8; -fx-font-size: 13px;" />
                        <Label fx:id="taxLabel" text="0.00" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;" />
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="Discount:" style="-fx-text-fill: #7B90A8; -fx-font-size: 13px;" />
                        <TextField fx:id="discountField" promptText="0.00" prefWidth="60" styleClass="search-field" style="-fx-padding: 2px 6px; -fx-font-size: 12px;"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 6px 0 0 0;">
                        <Label text="Total:" style="-fx-text-fill: #E2E8F0; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <Label fx:id="totalLabel" text="0.00"
                               style="-fx-text-fill: #34D399; -fx-font-size: 22px; -fx-font-weight: bold;" />
                    </HBox>
                    <Button text="💳  Checkout" onAction="#checkout" styleClass="primary-btn" maxWidth="Infinity" style="-fx-font-size: 14px; -fx-padding: 10px;" />
                </VBox>
            </VBox>
        </VBox>

    </HBox>

</VBox>
