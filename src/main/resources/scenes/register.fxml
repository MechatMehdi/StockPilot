<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.canvas.Canvas?>

<StackPane
    styleClass="auth-root"
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="application.controller.AuthController">

    <!-- Background: two large decorative blue lines drawn via Canvas -->
    <Canvas fx:id="bgCanvas" />

    <!-- Main content -->
    <HBox alignment="CENTER" fillHeight="true">

        <!-- ── Left panel: mascot + branding ───────────────────── -->
        <VBox alignment="CENTER" spacing="24" HBox.hgrow="ALWAYS" fillWidth="true"
              style="-fx-padding: 60px 40px;">

            <!-- Logo and Brand wordmark -->
            <VBox alignment="CENTER" spacing="16">
                <ImageView fitWidth="120" fitHeight="120" preserveRatio="true" styleClass="mascot-panel">
                    <image><Image url="@../photos/image.png" /></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="Join StockPilot" style="-fx-font-size:40px;-fx-font-weight:bold;-fx-text-fill:white;" />
                    <Label text="Start managing your inventory today"
                           style="-fx-font-size:15px;-fx-text-fill:#7B90A8;" />
                </VBox>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 20px 0 0 0;">
                <Label text="📦  Manage products and categories"
                       style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
                <Label text="📊  Visual dashboard &amp; KPIs"
                       style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
                <Label text="📱  Mobile barcode scanning"
                       style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
            </VBox>
        </VBox>

        <!-- ── Right panel: register card ──────────────────────── -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" fillWidth="true"
              style="-fx-padding: 60px 80px 60px 40px;">

            <VBox spacing="22" styleClass="auth-card" maxWidth="420" minWidth="360">

                <!-- Card top accent bar -->
                <Region styleClass="auth-brand-bar" />

                <VBox spacing="6" alignment="CENTER">
                    <Label text="Create Account" styleClass="title-label"
                           style="-fx-font-size:26px;" />
                    <Label text="Fill in the details below to get started"
                           styleClass="subtitle-label" />
                </VBox>

                <VBox spacing="6">
                    <Label text="USERNAME" styleClass="field-label" />
                    <TextField fx:id="txtNewUsername" promptText="Choose a username" />
                </VBox>

                <VBox spacing="6">
                    <Label text="PASSWORD" styleClass="field-label" />
                    <PasswordField fx:id="txtNewPassword" promptText="Create a password" />
                </VBox>

                <VBox spacing="6">
                    <Label text="CONFIRM PASSWORD" styleClass="field-label" />
                    <PasswordField fx:id="txtConfirmPassword" promptText="Repeat your password" />
                </VBox>

                <Button onAction="#signup" text="Create Account →"
                        maxWidth="Infinity"
                        styleClass="primary-btn"
                        style="-fx-padding:13px 22px;-fx-font-size:15px;" />

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Already have an account?" styleClass="subtitle-label"
                           style="-fx-font-size:13px;" />
                    <Hyperlink onAction="#goToLogin" text="Sign in" />
                </HBox>
            </VBox>
        </VBox>

    </HBox>
</StackPane>
