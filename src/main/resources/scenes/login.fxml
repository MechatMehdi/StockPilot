<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<StackPane
    styleClass="auth-root"
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="application.controller.AuthController">

    <!-- Background: two large decorative blue lines drawn via Canvas -->
    <Canvas fx:id="bgCanvas" />

    <!-- Main content — fills available space -->
    <HBox alignment="CENTER" fillHeight="true">

        <!-- ── Left panel: branding + mascot ───────────────────── -->
        <VBox alignment="CENTER" spacing="24" HBox.hgrow="ALWAYS" fillWidth="true"
              style="-fx-padding: 60px 40px;">

            <!-- Logo and Brand wordmark -->
            <VBox alignment="CENTER" spacing="16">
                <ImageView fitWidth="120" fitHeight="120" preserveRatio="true" styleClass="mascot-panel">
                    <image><Image url="@../photos/image.png" /></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="StockPilot" style="-fx-font-size:42px;-fx-font-weight:bold;-fx-text-fill:white;" />
                    <Label text="Your smart inventory companion"
                           style="-fx-font-size:16px;-fx-text-fill:#7B90A8;" />
                </VBox>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 20px 0 0 0;">
                <Label text="✓  Real-time inventory tracking"
                       style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
                <Label text="✓  Smart low-stock alerts"
                       style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
                <Label text="✓  Barcode scanner integration"
                       style="-fx-text-fill:#7B90A8;-fx-font-size:13px;" />
            </VBox>
        </VBox>

        <!-- ── Right panel: login card ──────────────────────────── -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" fillWidth="true"
              style="-fx-padding: 60px 80px 60px 40px;">

            <VBox spacing="24" styleClass="auth-card" maxWidth="420" minWidth="360">

                <!-- Card top accent bar -->
                <Region styleClass="auth-brand-bar" />

                <VBox spacing="6" alignment="CENTER">
                    <Label text="Welcome back 👋" styleClass="title-label"
                           style="-fx-font-size:26px;" />
                    <Label text="Sign in to your account" styleClass="subtitle-label" />
                </VBox>

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="USERNAME" styleClass="field-label" />
                    <TextField fx:id="txtLoginUsername"
                               promptText="Enter your username" />
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="PASSWORD" styleClass="field-label" />
                    <PasswordField fx:id="txtLoginPassword"
                                   promptText="Enter your password" />
                </VBox>

                <!-- Sign In button -->
                <Button onAction="#login" text="Sign In →"
                        maxWidth="Infinity"
                        styleClass="primary-btn"
                        style="-fx-padding:13px 22px;-fx-font-size:15px;" />

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Don't have an account?" styleClass="subtitle-label"
                           style="-fx-font-size:13px;" />
                    <Hyperlink onAction="#goToSignup" text="Sign up" />
                </HBox>
            </VBox>
        </VBox>

    </HBox>
</StackPane>
